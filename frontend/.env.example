VITE_API_BASE_URL=http://localhost:3000/api/v1
# Chrome extension ID (chrome://extensions → R.I.P Market → ID)
# VITE_EXTENSION_ID=your-extension-id-here
# Local dev: true. Staging: false (see .env.staging.example)
VITE_ENABLE_MOCK_TRADE=true
# Set to true on staging deploy to hide mock panels for non-admin users
# VITE_STAGING=true
# VITE_SUPPORT_EMAIL=support@your-domain.com
