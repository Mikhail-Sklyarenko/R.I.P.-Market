{
  "name": "@rip-market/browser-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/verify-dist.mjs && node scripts/copy-static.mjs",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rip-market/extension-orchestrator": "file:../extension"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.304",
    "esbuild": "^0.25.12",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.5"
  }
}
