# Repo-root staging env for docker compose (crypto gateway stack).
# Copy to .env.staging in repo root, then:
#   docker compose --env-file .env.staging -f docker-compose.staging.yml up -d
#   docker compose --env-file .env.staging -f docker-compose.staging.yml --profile prod up -d

# Platform Postgres (optional service in compose)
PLATFORM_POSTGRES_PASSWORD=replace-with-strong-password

# Gateway — must match backend/.env on platform host
CRYPTO_GATEWAY_API_KEY=replace-with-random-api-key
CRYPTO_GATEWAY_WEBHOOK_SECRET=replace-with-random-webhook-secret
GATEWAY_POSTGRES_PASSWORD=replace-with-strong-gateway-db-password
GATEWAY_XPUB=xpub6...
PLATFORM_WEBHOOK_URL=https://api-staging.example.com/api/v1/payments/webhooks/crypto

# TRON mainnet
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_GRID_API_KEY=
MIN_CONFIRMATIONS=19
MIN_DEPOSIT_SUN=5000000

# Signer (prod profile only — store in secret manager, not git)
GATEWAY_MNEMONIC=
GATEWAY_HOT_WALLET_ADDRESS=
