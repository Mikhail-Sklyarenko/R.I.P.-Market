# Staging backend — copy to .env on deploy host
DATABASE_URL="postgresql://USER:PASS@HOST:5432/cs2_p2p_mvp?schema=public"
PORT=3000
JWT_SECRET="replace-with-strong-random-secret"
JWT_EXPIRES_IN="7d"
FRONTEND_ORIGIN="https://staging.example.com"

AUTH_PROVIDER=mock
INVENTORY_PROVIDER=mock
TRADE_PROVIDER=mock
ENABLE_MOCK_TRADE=true
ENABLE_MOCK_DEPOSIT=true
