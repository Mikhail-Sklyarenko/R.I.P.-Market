DATABASE_URL="postgresql://cs2:cs2@localhost:5432/cs2_p2p_mvp?schema=public"
PORT=3000
JWT_SECRET="dev-jwt-secret"
JWT_EXPIRES_IN="7d"
FRONTEND_ORIGIN="http://localhost:5173"

# Provider selection: mock | steam
AUTH_PROVIDER=mock
INVENTORY_PROVIDER=mock
TRADE_PROVIDER=mock
# TRADE_VERIFICATION_MODE=off | shadow | live  (legacy: STEAM_POLL → live)
#   live: poll Steam and transition order status (required for production)
#   shadow: poll only records snapshots — orders stay WAITING_TRADE
# STEAM_WEB_API_KEY=""  # required on staging/production for GetTradeOffer poll (without it offer status = unknown)
# ENABLE_DELIVERY_VERIFICATION_ENGINE=true
# TRADE_POLL_BACKOFF_MS=60000
# DELIVERY_ACCEPTED_INVENTORY_PENDING_MAX_CHECKS=20
# STEAM_SETTLEMENT_ALLOWLIST_STEAM_IDS=76561198...,76561198...
# STEAM_SETTLEMENT_MAX_ORDER_MINOR=50000
# STEAM_SETTLEMENT_MAX_DAILY_ORDERS=3
# STEAM_SETTLEMENT_MAX_DAILY_VOLUME_MINOR=150000
ENABLE_MOCK_TRADE=true
# Dev: POST /api/v1/test/reset-dev-trades (JWT seller) resets SOLD/RESERVED assets after mock trades
ENABLE_MOCK_DEPOSIT=true

# USDT TRC-20 payments (v2 closed beta)
# PAYMENT_PROVIDER=crypto_tron
# ENABLE_MOCK_DEPOSIT=false
# CRYPTO_GATEWAY_URL=http://localhost:3100
# CRYPTO_GATEWAY_API_KEY=replace-with-gateway-api-key
# CRYPTO_GATEWAY_WEBHOOK_SECRET=replace-with-webhook-secret
# MIN_DEPOSIT_MINOR=500
# MIN_WITHDRAW_MINOR=2000
# WITHDRAW_FEE_MINOR=200
# WITHDRAW_MANUAL_REVIEW=true
# WITHDRAW_MANUAL_REVIEW_COUNT=3
# WITHDRAW_REQUIRE_STEAM_LINKED=true
# WITHDRAW_MIN_COMPLETED_SALES=0
# WITHDRAW_DAILY_CAP_MINOR=0

# Staging: use a strong unique JWT_SECRET (see .env.staging.example)

# Steam Market price hints (catalog, lot page, inventory)
# STEAM_MARKET_PRICE_ENABLED=false

# Residential HTTP proxy for ALL server-side Steam egress
# (OpenID verify, inventory, market prices, Web API). DataImpulse example:
# STEAM_HTTP_PROXY=http://LOGIN:PASSWORD@gw.dataimpulse.com:823

# External reference prices (Buff / CSFloat) — hints only, not deal price
# REFERENCE_PRICE_ENABLED=true
# BUFF_REFERENCE_PRICE_ENABLED=true
# CSFLOAT_REFERENCE_PRICE_ENABLED=true
# REFERENCE_PRICE_CACHE_TTL_MINUTES=30

# Inventory sync (used when INVENTORY_PROVIDER=steam)
INVENTORY_SYNC_TTL_SECONDS=300
INVENTORY_SYNC_MIN_INTERVAL_MS=60000

# --- Extension-first (Stage 1: internal rollout) ---
# ENABLE_EXTENSION_CHANNEL=true
# ENABLE_EXTENSION_ROLLOUT=true
# EXTENSION_ROLLOUT_STAGE=internal
# EXTENSION_ROLLOUT_KILL_SWITCH=false
# EXTENSION_ROLLOUT_INFLIGHT_GRACE=true
# EXTENSION_ROLLOUT_INTERNAL_USER_IDS=
# EXTENSION_ROLLOUT_INTERNAL_STEAM_IDS=
# ENABLE_EXTENSION_TASK_PIPELINE=true
# ENABLE_EXTENSION_OFFER_ORCHESTRATOR=true
# ENABLE_EXTENSION_TRADE_REFERENCE=true
# ENABLE_EXTENSION_UI_TRADE_FLOW=true
# ENABLE_EXTENSION_TRADE_ACKNOWLEDGMENT=true
#   Internal trade confirmation in extension (active trades, verify overlay, buyer ack)
#   UI trade (default after cutover): extension fills Steam trade page in-browser.
#   Flag off: legacy direct Steam API path. Emergency API override in extension:
#   chrome.storage.local.set({ USE_DIRECT_TRADE_API: true })
# ENABLE_TRADE_REFERENCE_RECONCILE=true
# ENABLE_EXTENSION_FIRST_TRADE_FLOW=true
# ENABLE_DELIVERY_VERIFICATION_ENGINE=true
# 8-day seller payout hold — ONLY applies when ENABLE_REAL_SETTLEMENT=true.
# With real settlement off (staging/mock), payouts are immediate.
# ENABLE_SETTLEMENT_HOLD_WINDOW=true
# ENABLE_REAL_SETTLEMENT=false
# VAC: required automatically when AUTH/INVENTORY_PROVIDER=steam (fail-closed without STEAM_WEB_API_KEY).
# VAC_CHECK_REQUIRED=true
# STEAM_WEB_API_KEY=""  # required for VAC + trade poll on steam staging/production
# ENABLE_EXTENSION_DISPUTE_BRIDGE=true
# ENABLE_EXTENSION_FLOW_OBSERVABILITY=true
# EXTENSION_TOKEN_TTL_SECONDS=3600
# EXTENSION_TASK_MAX_ATTEMPTS=5
# EXTENSION_TASK_TTL_MS=1800000

# Steam OpenID (used when AUTH_PROVIDER=steam)
# Realm = API origin without path (see docs/phase-4-steam-auth.md)
STEAM_OPENID_REALM="http://localhost:3000"
# API_PUBLIC_URL="http://localhost:3000/api/v1"
# STEAM_WEB_API_KEY=""  # VAC + GetTradeOffer poll; required when VAC_CHECK_REQUIRED or steam providers
# ALLOW_MOCK_LOGIN_IN_STEAM_MODE=false  # true: mock login + reassign Steam link to mock user (dev)
