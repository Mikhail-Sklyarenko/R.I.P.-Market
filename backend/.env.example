DATABASE_URL="postgresql://cs2:cs2@localhost:5432/cs2_p2p_mvp?schema=public"
PORT=3000
JWT_SECRET="dev-jwt-secret"
JWT_EXPIRES_IN="7d"
FRONTEND_ORIGIN="http://localhost:5173"

# Provider selection: mock | steam
AUTH_PROVIDER=mock
INVENTORY_PROVIDER=mock
TRADE_PROVIDER=mock
# TRADE_VERIFICATION_MODE=STEAM_POLL
# TRADE_POLL_INTERVAL_SECONDS=30
# TRADE_TIMEOUT_MINUTES=60
# TRADE_FAIL_MODE=DISPUTE
# TRADE_POLL_BACKOFF_MS=120000
# ENABLE_REAL_SETTLEMENT=false
ENABLE_MOCK_TRADE=true
ENABLE_MOCK_DEPOSIT=true

# Inventory sync (used when INVENTORY_PROVIDER=steam)
INVENTORY_SYNC_TTL_SECONDS=300
INVENTORY_SYNC_MIN_INTERVAL_MS=60000

# Steam OpenID (used when AUTH_PROVIDER=steam)
# Realm = API origin without path (see docs/phase-4-steam-auth.md)
STEAM_OPENID_REALM="http://localhost:3000"
# API_PUBLIC_URL="http://localhost:3000/api/v1"
# STEAM_WEB_API_KEY=""
# ALLOW_MOCK_LOGIN_IN_STEAM_MODE=false
