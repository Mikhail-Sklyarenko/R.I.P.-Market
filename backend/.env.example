DATABASE_URL="postgresql://cs2:cs2@localhost:5432/cs2_p2p_mvp?schema=public"
PORT=3000
JWT_SECRET="dev-jwt-secret"
JWT_EXPIRES_IN="7d"
FRONTEND_ORIGIN="http://localhost:5173"

# Provider selection: mock | steam
AUTH_PROVIDER=mock
INVENTORY_PROVIDER=mock
TRADE_PROVIDER=mock
# TRADE_VERIFICATION_MODE=off | shadow | live  (legacy: STEAM_POLL → live)
# ENABLE_REAL_SETTLEMENT=false  # MUST be false in shadow mode; kill switch for rollback
# STEAM_SETTLEMENT_ALLOWLIST_STEAM_IDS=76561198...,76561198...
# STEAM_SETTLEMENT_MAX_ORDER_MINOR=50000
# STEAM_SETTLEMENT_MAX_DAILY_ORDERS=3
# STEAM_SETTLEMENT_MAX_DAILY_VOLUME_MINOR=150000
ENABLE_MOCK_TRADE=true
ENABLE_MOCK_DEPOSIT=true

# Staging: use a strong unique JWT_SECRET (see .env.staging.example)

# Inventory sync (used when INVENTORY_PROVIDER=steam)
INVENTORY_SYNC_TTL_SECONDS=300
INVENTORY_SYNC_MIN_INTERVAL_MS=60000

# Steam OpenID (used when AUTH_PROVIDER=steam)
# Realm = API origin without path (see docs/phase-4-steam-auth.md)
STEAM_OPENID_REALM="http://localhost:3000"
# API_PUBLIC_URL="http://localhost:3000/api/v1"
# STEAM_WEB_API_KEY=""
# ALLOW_MOCK_LOGIN_IN_STEAM_MODE=false  # true: mock login + reassign Steam link to mock user (dev)
