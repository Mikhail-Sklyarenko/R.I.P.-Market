# Crypto gateway — staging (copy to repo-root .env.staging for docker compose, or crypto-gateway/.env on host deploy)
#
# Used by: docker compose -f docker-compose.staging.yml [--profile prod] up -d
# See docs/payments-crypto-tron.md

# --- Shared secrets (must match platform backend) ---
CRYPTO_GATEWAY_API_KEY=replace-with-random-api-key
CRYPTO_GATEWAY_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Platform webhook target (reachable from gateway containers)
PLATFORM_WEBHOOK_URL=https://api-staging.example.com/api/v1/payments/webhooks/crypto

# --- Gateway DB (docker-compose service crypto-gateway-db) ---
GATEWAY_POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://gateway:replace-with-strong-password@crypto-gateway-db:5432/crypto_gateway?schema=public

# --- API / scanner ---
PORT=3001
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
MIN_CONFIRMATIONS=19
MIN_DEPOSIT_SUN=5000000
TRON_GRID_API_KEY=
TRON_GRID_BASE_URL=https://api.trongrid.io
SCANNER_INTERVAL_MS=15000

# XPUB for deposit address derivation (api + scanner; no MNEMONIC)
GATEWAY_XPUB=xpub6...

# --- Signer only (prod profile; never set on api/scanner) ---
GATEWAY_MNEMONIC=
GATEWAY_HOT_WALLET_ADDRESS=
SWEEP_INTERVAL_HOURS=6
WITHDRAWAL_FEE_SUN=0
MAX_WITHDRAWAL_SUN=100000000000
